parameters:
    level: 5
    paths:
        - src
        - config
        - presets/blade/src
        - presets/livewire/src
        - presets/filament/src
        - presets/vue/src
    tmpDir: build/phpstan
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        -
            identifier: larastan.noEnvCallsOutsideOfConfig
            path: config/license-verifier-ui.php
