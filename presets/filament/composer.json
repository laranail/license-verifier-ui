{
    "name": "laranail/license-verifier-ui-filament",
    "description": "Filament UI preset for laranail/license-verifier-ui \u2014 generates an owned license management page + status widget plugin.",
    "keywords": [
        "laravel",
        "license",
        "filament",
        "ui",
        "preset",
        "laranail"
    ],
    "homepage": "https://opensource.simtabi.com/documentation/laranail/license-verifier-ui/",
    "license": "MIT",
    "authors": [
        {
            "name": "Simtabi LLC",
            "email": "opensource@simtabi.com",
            "homepage": "https://opensource.simtabi.com",
            "role": "Organization"
        },
        {
            "name": "Imani Manyara",
            "email": "imani@simtabi.com",
            "role": "Maintainer"
        }
    ],
    "require": {
        "php": "^8.4 || ^8.5",
        "illuminate/support": "^13.0",
        "laranail/license-verifier-ui": "^0.1",
        "filament/filament": "^4.0 || ^3.2"
    },
    "autoload": {
        "psr-4": {
            "Simtabi\\Laranail\\Licence\\Verifier\\Presets\\Filament\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Simtabi\\Laranail\\Licence\\Verifier\\Presets\\Filament\\Providers\\FilamentServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
